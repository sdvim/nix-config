# Font
font-family = JetBrainsMono Nerd Font

theme = GitHub Dark High Contrast
background = #000000
cursor-color = #ffffff

# Hide tab bar entirely
window-show-tab-bar = never

# Hide titlebar and window decorations
macos-titlebar-style = hidden
window-padding-y = 0

# Skip quit confirmation (tmux preserves sessions)
confirm-close-surface = false

# Clear Ghostty default keybinds (goto_tab conflicts with tmux bindings)
keybind = clear

# Re-add essentials
keybind = super+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard
keybind = super+left=text:\x01
keybind = super+right=text:\x05
keybind = alt+left=text:\x1b[1;3D
keybind = alt+right=text:\x1b[1;3C
keybind = super+shift+/=text:\x02?
keybind = super+ctrl+f=toggle_fullscreen
keybind = super+q=quit
keybind = super+k=text:\x02K
keybind = super+n=text:\x02N
keybind = super+grave_accent=text:\x02n
keybind = super+g=text:\x02G

# Tmux panes (select by number)
keybind = super+t=text:\x02c
keybind = super+0=text:\x020
keybind = super+1=text:\x021
keybind = super+2=text:\x022
keybind = super+3=text:\x023
keybind = super+4=text:\x024
keybind = super+5=text:\x025
keybind = super+6=text:\x026
keybind = super+7=text:\x027
keybind = super+8=text:\x028
keybind = super+9=text:\x029

# Tmux windows (shift+cmd+N sends prefix + Alt+N)
keybind = super+shift+0=text:\x02\x1b0
keybind = super+shift+1=text:\x02\x1b1
keybind = super+shift+2=text:\x02\x1b2
keybind = super+shift+3=text:\x02\x1b3
keybind = super+shift+4=text:\x02\x1b4
keybind = super+shift+5=text:\x02\x1b5
keybind = super+shift+6=text:\x02\x1b6
keybind = super+shift+7=text:\x02\x1b7
keybind = super+shift+8=text:\x02\x1b8
keybind = super+shift+9=text:\x02\x1b9

keybind = super+w=text:\x02x
keybind = super+shift+bracket_left=text:\x02p
keybind = super+shift+bracket_right=text:\x02n
keybind = ctrl+tab=text:\x02n
keybind = ctrl+shift+tab=text:\x02p

# Tmux panes (replaces Ghostty splits)
keybind = super+d=text:\x02%
keybind = super+shift+d=text:\x02\x22
keybind = super+bracket_left=text:\x02O
keybind = super+bracket_right=text:\x02o
keybind = super+shift+enter=text:\x02z

# Shift+enter sends CSI 13;2u (kitty protocol) for apps like Claude Code
keybind = shift+enter=text:\x1b[13;2u

# Launch into tmux
command = /Users/stevedv/.local/bin/tmux-session

# Quick terminal (ctrl+')
keybind = global:ctrl+apostrophe=toggle_quick_terminal
quick-terminal-position = center
quick-terminal-size = 100%
quick-terminal-autohide = true
quick-terminal-animation-duration = 0
