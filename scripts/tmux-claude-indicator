#!/bin/bash
window="$1"
result=""
has_alert=0
while IFS=$'\t' read -r cmd waiting; do
  if [[ "$cmd" =~ ^[0-9] ]]; then
    if [[ "$waiting" == "1" ]]; then
      result+="!"
      has_alert=1
    else
      result+="✱"
    fi
  fi
done < <(tmux list-panes -t "$window" -F '#{pane_current_command}	#{@claude_waiting}' 2>/dev/null)

# Set window-level variable for tmux format coloring
if [[ $has_alert -eq 1 ]]; then
  tmux set-option -t "$window" -w @window_has_alerts 1 2>/dev/null
else
  tmux set-option -t "$window" -w -u @window_has_alerts 2>/dev/null
fi

echo "$result"
