#!/usr/bin/env bash
set -euo pipefail

pane_path="${1:-}"
caller_pane="${2:-}"
tmux_bin=/etc/profiles/per-user/stevedv/bin/tmux

if [ -z "$pane_path" ] || [ -z "$caller_pane" ]; then
  "$tmux_bin" display-message "Usage: tmux-edit-recent <pane_path> <pane_id>"
  exit 1
fi

current_window="$("$tmux_bin" display -t "$caller_pane" -p '#{window_id}')"

# --- File detection function (tiers 1/2/3 + line extraction) ---
detect_file() {
  file=""
  line=1

  # Tier 1: Parse tmux scrollback for Claude Code edit patterns
  scrollback="$("$tmux_bin" capture-pane -t "$caller_pane" -p -S -500 2>/dev/null || true)"
  if [ -n "$scrollback" ]; then
    match="$(echo "$scrollback" | grep -oE '(Update|Write|Edit)\([^)]+\)' | grep -v '(\.\.\.)$' | tail -1 || true)"
    if [ -n "$match" ]; then
      candidate="$(echo "$match" | sed 's/^[^(]*(\(.*\))$/\1/')"
      if [ -n "$candidate" ] && [ "$candidate" != "<path>" ] && [ "$candidate" != "<file>" ] && [ "$candidate" != "..." ]; then
        if [[ "$candidate" = /* ]]; then
          [ -f "$candidate" ] && file="$candidate"
        else
          [ -f "$pane_path/$candidate" ] && file="$pane_path/$candidate"
        fi
      fi
    fi
  fi

  # Tier 2: git diff (unstaged, staged, last commit) — most recently modified first
  if [ -z "$file" ] && { [ -d "$pane_path/.git" ] || git -C "$pane_path" rev-parse --git-dir >/dev/null 2>&1; }; then
    all_candidates="$(
      for diff_args in "" "--cached" "HEAD~1"; do
        git -C "$pane_path" diff $diff_args --name-only 2>/dev/null || true
      done | sort -u
    )"
    if [ -n "$all_candidates" ]; then
      candidate="$(echo "$all_candidates" | while IFS= read -r f; do
        [ -f "$pane_path/$f" ] && echo "$f" || true
      done | xargs -I{} stat -f '%m %N' "$pane_path/{}" 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2- || true)"
      [ -n "$candidate" ] && file="$candidate"
    fi
  fi

  # Tier 3: Recently modified tracked files
  if [ -z "$file" ]; then
    candidate="$(git -C "$pane_path" ls-files -m 2>/dev/null | head -1 || true)"
    if [ -n "$candidate" ] && [ -f "$pane_path/$candidate" ]; then
      file="$pane_path/$candidate"
    fi
  fi

  # Extract line number from git diff hunk header
  if [ -n "$file" ]; then
    rel_path="$(git -C "$pane_path" ls-files --full-name "$file" 2>/dev/null || true)"
    if [ -z "$rel_path" ]; then
      repo_root="$(git -C "$pane_path" rev-parse --show-toplevel 2>/dev/null || true)"
      [ -n "$repo_root" ] && rel_path="${file#$repo_root/}"
    fi
    if [ -n "$rel_path" ]; then
      hunk=""
      for diff_args in "" "--cached"; do
        hunk="$(git -C "$pane_path" diff $diff_args -U0 -- "$rel_path" 2>/dev/null | grep -m1 '^@@' || true)"
        [ -n "$hunk" ] && break
      done
      if [ -n "$hunk" ]; then
        diff_line="$(echo "$hunk" | sed -n 's/^@@ [^ ]* +\([0-9]*\).*/\1/p')"
        [ -n "$diff_line" ] && line="$diff_line"
      fi
    fi
  fi
}

# --- Check for existing editor pane ---
edit_pane="$("$tmux_bin" show -wqv -t "$current_window" @edit_pane 2>/dev/null || true)"

# Verify pane is still alive
if [ -n "$edit_pane" ]; then
  if ! "$tmux_bin" display -t "$edit_pane" -p '#{pane_id}' >/dev/null 2>&1; then
    "$tmux_bin" set-option -wu -t "$current_window" @edit_pane 2>/dev/null || true
    edit_pane=""
  fi
fi

if [ -n "$edit_pane" ]; then
  # Pane exists — check if it's in the current window (visible) or hidden
  edit_pane_window="$("$tmux_bin" display -t "$edit_pane" -p '#{window_id}' 2>/dev/null || true)"

  if [ -z "$edit_pane_window" ]; then
    # Pane died between the check and here (race condition)
    "$tmux_bin" set-option -wu -t "$current_window" @edit_pane 2>/dev/null || true
    edit_pane=""
  elif [ "$edit_pane_window" = "$current_window" ]; then
    # HIDE: break nvim pane to a hidden window
    "$tmux_bin" break-pane -d -s "$edit_pane" 2>/dev/null || true
    exit 0
  else
    # SHOW: bring hidden nvim pane back
    detect_file
    if [ -n "$file" ]; then
      "$tmux_bin" send-keys -t "$edit_pane" Escape
      "$tmux_bin" send-keys -t "$edit_pane" ":edit +$line $file" Enter
    fi
    "$tmux_bin" join-pane -v -l 40% -s "$edit_pane" -t "$caller_pane"
    "$tmux_bin" run-shell -b \
      "sleep 0.2; nvim_pid=\$($tmux_bin display -t $edit_pane -p '#{pane_pid}'); kill -WINCH \$nvim_pid 2>/dev/null || true"
    exit 0
  fi
fi

# --- SPAWN: No existing editor pane ---
detect_file

if [ -z "$file" ]; then
  "$tmux_bin" display-message "No recently edited file found"
  exit 0
fi

new_pane="$("$tmux_bin" split-window -v -l 40% -c "$pane_path" -P -F '#{pane_id}' \
  "nvim +$line '$file'")"
"$tmux_bin" set-option -w -t "$current_window" @edit_pane "$new_pane"
"$tmux_bin" run-shell -b \
  "sleep 0.2; nvim_pid=\$($tmux_bin display -t $new_pane -p '#{pane_pid}'); kill -WINCH \$nvim_pid 2>/dev/null || true"
