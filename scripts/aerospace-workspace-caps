#!/usr/bin/env bash
set -euo pipefail

AEROSPACE_BIN="${AEROSPACE_BIN:-aerospace}"
TERMINAL_WORKSPACE='`'

display_metadata() {
  system_profiler SPDisplaysDataType -json 2>/dev/null
}

monitor_json() {
  "$AEROSPACE_BIN" list-monitors --json 2>/dev/null
}

primary_monitor_id() {
  local monitors_json displays_json primary_name primary_id
  monitors_json="$(monitor_json)"
  displays_json="$(display_metadata)"
  primary_name="$(printf '%s' "$displays_json" | jq -r '
    .SPDisplaysDataType[]
    | .spdisplays_ndrvs[]?
    | select(.spdisplays_main? == "spdisplays_yes")
    | ._name
  ' | head -n1)"

  if [[ -n "$primary_name" && "$primary_name" != "null" ]]; then
    primary_id="$(printf '%s' "$monitors_json" | jq -r --arg name "$primary_name" '
      map(select(."monitor-name" == $name)) | .[0]."monitor-id" // empty
    ')"
  fi

  if [[ -z "${primary_id:-}" ]]; then
    primary_id="$(printf '%s' "$monitors_json" | jq -r '.[0]."monitor-id" // empty')"
  fi

  printf '%s\n' "$primary_id"
}

monitor_cap() {
  local monitor_id="$1"
  local displays_json monitors_json monitor_name resolution width height aspect

  displays_json="$(display_metadata)"
  monitors_json="$(monitor_json)"
  monitor_name="$(printf '%s' "$monitors_json" | jq -r --argjson id "$monitor_id" '
    map(select(."monitor-id" == $id)) | .[0]."monitor-name" // empty
  ')"

  if [[ "$monitor_name" == *"Built-in"* || "$monitor_name" == *"built-in"* ]]; then
    echo 1
    return
  fi

  resolution="$(printf '%s' "$displays_json" | jq -r --arg name "$monitor_name" '
    .SPDisplaysDataType[]
    | .spdisplays_ndrvs[]?
    | select(._name == $name)
    | ._spdisplays_resolution // ._spdisplays_pixels // .spdisplays_resolution // empty
  ' | head -n1)"

  if [[ "$resolution" =~ ([0-9]+)\ x\ ([0-9]+) ]]; then
    width="${BASH_REMATCH[1]}"
    height="${BASH_REMATCH[2]}"
    if (( width >= 3400 )); then
      echo 4
      return
    fi
    aspect="$(awk -v w="$width" -v h="$height" 'BEGIN { if (h == 0) { print 0 } else { printf "%.4f", w / h } }')"
    if awk -v a="$aspect" 'BEGIN { exit !(a >= 2.2) }'; then
      echo 4
      return
    fi
  fi

  echo 2
}

workspace_count() {
  local workspace="$1"
  "$AEROSPACE_BIN" list-windows --workspace "$workspace" --count 2>/dev/null || echo 0
}

focused_workspace() {
  "$AEROSPACE_BIN" list-workspaces --focused 2>/dev/null | head -n1
}

focused_window_id() {
  "$AEROSPACE_BIN" list-windows --focused --format '%{window-id}' 2>/dev/null | head -n1
}

highest_window_id() {
  local workspace="$1"
  "$AEROSPACE_BIN" list-windows --workspace "$workspace" --format '%{window-id}' 2>/dev/null | sort -nr | head -n1
}

window_workspace() {
  local window_id="$1"
  "$AEROSPACE_BIN" list-windows --monitor all --format '%{window-id}|%{workspace}' 2>/dev/null \
    | awk -F'|' -v id="$window_id" '$1 == id { print $2; exit }'
}

nearest_available_workspace() {
  local source="$1"
  local cap="$2"
  shift 2
  local pool=("$@")
  local index=-1 size offset left_index right_index left right candidate
  local seen=" "

  size="${#pool[@]}"
  for ((index = 0; index < size; index++)); do
    if [[ "${pool[index]}" == "$source" ]]; then
      break
    fi
  done

  if (( index < 0 || index >= size )); then
    return 1
  fi

  for ((offset = 1; offset < size; offset++)); do
    right_index=$(( (index + offset) % size ))
    right="${pool[right_index]}"
    if [[ "$right" != "$source" && "$seen" != *" $right "* ]] && [[ "$(workspace_count "$right")" -lt "$cap" ]]; then
      printf '%s\n' "$right"
      return 0
    fi
    seen+=" $right "

    left_index=$(( (index - offset + size) % size ))
    left="${pool[left_index]}"
    if [[ "$left" != "$source" && "$seen" != *" $left "* ]] && [[ "$(workspace_count "$left")" -lt "$cap" ]]; then
      printf '%s\n' "$left"
      return 0
    fi
    seen+=" $left "
  done

  return 1
}

reconcile_workspace() {
  local workspace="$1"
  local cap="$2"
  local preferred_window_id="${3:-}"
  shift 3 || true
  local pool=("$@")
  local count target window_id

  count="$(workspace_count "$workspace")"
  while [[ "$count" -gt "$cap" ]]; do
    if ! target="$(nearest_available_workspace "$workspace" "$cap" "${pool[@]}")"; then
      break
    fi

    window_id=""
    if [[ -n "$preferred_window_id" ]] && [[ "$(window_workspace "$preferred_window_id")" == "$workspace" ]]; then
      window_id="$preferred_window_id"
      preferred_window_id=""
    else
      window_id="$(highest_window_id "$workspace")"
    fi

    [[ -n "$window_id" ]] || break
    "$AEROSPACE_BIN" move-node-to-workspace --window-id "$window_id" "$target" >/dev/null 2>&1 || break
    count="$(workspace_count "$workspace")"
  done
}

reconcile_monitor() {
  local monitor_id="$1"
  local primary_id="$2"
  local total_monitors="$3"
  local cap focused_ws focused_window preferred_window_id
  local pool=()

  cap="$(monitor_cap "$monitor_id")"
  if [[ "$total_monitors" -le 1 ]]; then
    pool=(1 2 3 4 5)
  elif [[ "$monitor_id" == "$primary_id" ]]; then
    pool=(1 2 3)
  else
    pool=(4 5)
  fi

  focused_ws="$(focused_workspace)"
  focused_window="$(focused_window_id)"

  for workspace in "${pool[@]}"; do
    preferred_window_id=""
    if [[ "$workspace" == "$focused_ws" ]]; then
      preferred_window_id="$focused_window"
    fi
    reconcile_workspace "$workspace" "$cap" "$preferred_window_id" "${pool[@]}"
  done
}

main() {
  local monitors_json primary_id total_monitors
  local monitor_ids

  monitors_json="$(monitor_json)"
  total_monitors="$(printf '%s' "$monitors_json" | jq 'length')"
  primary_id="$(primary_monitor_id)"

  mapfile -t monitor_ids < <(printf '%s' "$monitors_json" | jq -r '.[]."monitor-id"')
  for monitor_id in "${monitor_ids[@]}"; do
    reconcile_monitor "$monitor_id" "$primary_id" "$total_monitors"
  done
}

main "$@"
