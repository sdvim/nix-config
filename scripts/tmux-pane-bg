#!/bin/bash
# Query terminal background via OSC 11, output a slightly lighter hex color.
# Runs BEFORE tmux (direct terminal access, no passthrough needed).
LIGHTEN=10

old_settings=$(stty -g)
stty raw -echo min 0 time 10

printf '\033]11;?\033\\'

response=""
while IFS= read -r -n 1 -t 1 char; do
  response+="$char"
  case "$response" in *\\) break ;; *$'\a') break ;; esac
done

stty "$old_settings"

rgb=$(echo "$response" | sed -n 's/.*rgb:\([0-9a-fA-F]*\)\/\([0-9a-fA-F]*\)\/\([0-9a-fA-F]*\).*/\1 \2 \3/p')

if [[ -z "$rgb" ]]; then
  echo "default"
  exit
fi

read -r r_hex g_hex b_hex <<< "$rgb"

r=$(( (16#${r_hex:0:2}) + LIGHTEN )); (( r > 255 )) && r=255
g=$(( (16#${g_hex:0:2}) + LIGHTEN )); (( g > 255 )) && g=255
b=$(( (16#${b_hex:0:2}) + LIGHTEN )); (( b > 255 )) && b=255

printf '#%02x%02x%02x\n' "$r" "$g" "$b"
